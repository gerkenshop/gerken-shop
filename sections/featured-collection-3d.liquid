{% assign collection_handle = section.settings.collection | default: 'all' %}
{% assign feature_collection = collections[collection_handle] %}

<section class="featured-collection-3d">
  <div class="page-width">
    <div class="section-heading">
      <div>
        <p class="section-eyebrow">Shop products</p>
        <h2>{{ section.settings.heading }}</h2>
      </div>
      <p>{{ section.settings.subheading }}</p>
    </div>

    <div class="product-grid">
      {% for product in feature_collection.products limit: section.settings.products_to_show %}
        <article class="product-card">
          <a class="product-card__visual" href="{{ product.url }}">
            {% if product.featured_image %}
              {{ product.featured_image | image_url: width: 900 | image_tag: loading: 'lazy', widths: '360, 540, 720, 900', class: 'product-card__image' }}
            {% else %}
              <div class="product-card__placeholder"></div>
            {% endif %}
          </a>
          <div class="product-card__content">
            <div class="product-card__meta">
              {% if product.type != blank %}<span>{{ product.type }}</span>{% endif %}
              {% if product.vendor != blank %}<span>{{ product.vendor }}</span>{% endif %}
            </div>
            <h3><a href="{{ product.url }}">{{ product.title }}</a></h3>
            <p>{{ product.description | strip_html | truncatewords: 18 }}</p>
            <div class="product-card__footer">
              <strong>{{ product.price | money }}</strong>
              <a class="button button--secondary" href="{{ product.url }}">View product</a>
            </div>
          </div>
        </article>
      {% else %}
        <article class="product-card product-card--empty">
          <div class="product-card__content">
            <h3>Add products to your Shopify store</h3>
            <p>This section is ready. Once products exist in the chosen collection, they will render here automatically.</p>
          </div>
        </article>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured collection 3D",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Popular 3D products" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Highlight your best margin-ready items and custom bundles." },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "range", "id": "products_to_show", "label": "Products to show", "min": 2, "max": 12, "step": 1, "default": 8 }
  ],
  "presets": [{ "name": "Featured collection 3D" }]
}
{% endschema %}
