<header class="site-header">
  <div class="page-width site-header__inner">
    <a class="site-logo" href="{{ routes.root_url }}">
      <span class="site-logo__mark">LF</span>
      <span>
        <small>Industrial-grade 3D selling</small>
        <strong>{{ shop.name }}</strong>
      </span>
    </a>

    <nav class="site-nav">
      <a href="{{ routes.all_products_collection_url }}">Catalog</a>
      <a href="/pages/custom-quote">Custom Quote</a>
      <a href="/collections/all">Collections</a>
      <a href="{{ routes.cart_url }}">Cart{% if cart.item_count > 0 %} ({{ cart.item_count }}){% endif %}</a>
    </nav>
  </div>
</header>

{% schema %}
{
  "name": "Site header",
  "settings": []
}
{% endschema %}
